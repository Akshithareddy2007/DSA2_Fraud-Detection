import java.util.*;

class Edge {
    int source;
    int destination;
    int weight;

    Edge(int source, int destination, int weight) {
        this.source = source;
        this.destination = destination;
        this.weight = weight;
    }
}

public class Main {

    static ArrayList<Edge> edges = new ArrayList<>();

    static void bellmanFord(int vertices, int source) {

        int[] distance = new int[vertices];
        Arrays.fill(distance, Integer.MAX_VALUE);

        distance[source] = 0;

        // Relax edges V-1 times
        for (int i = 1; i < vertices; i++) {
            for (Edge edge : edges) {

                if (distance[edge.source] != Integer.MAX_VALUE &&
                        distance[edge.source] + edge.weight < distance[edge.destination]) {

                    distance[edge.destination] =
                            distance[edge.source] + edge.weight;
                }
            }
        }

        // Check for negative cycle (fraud detection)
        boolean fraudDetected = false;

        for (Edge edge : edges) {
            if (distance[edge.source] != Integer.MAX_VALUE &&
                    distance[edge.source] + edge.weight < distance[edge.destination]) {

                fraudDetected = true;
                break;
            }
        }

        System.out.println("\n===== FINANCIAL RISK ANALYSIS =====");

        for (int i = 0; i < vertices; i++) {
            if (distance[i] == Integer.MAX_VALUE)
                System.out.println("Node " + i + " : Not Reachable");
            else
                System.out.println("Node " + i + " : Risk Score = " + distance[i]);
        }

        if (fraudDetected)
            System.out.println("\nALERT: Fraudulent Transaction Cycle Detected!");
        else
            System.out.println("\nNo Fraudulent Activity Detected.");
    }

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.println("====================================");
        System.out.println("      FINPULSE BANKING SYSTEM");
        System.out.println("====================================");

        System.out.print("Enter Number of Banking Nodes: ");
        int vertices = sc.nextInt();

        if (vertices <= 0) {
            System.out.println("Invalid number of nodes!");
            return;
        }

        System.out.print("Enter Number of Transactions: ");
        int transactions = sc.nextInt();

        System.out.println("\nNode IDs must be between 0 and " + (vertices - 1));

        for (int i = 0; i < transactions; i++) {

            System.out.println("\nTransaction " + (i + 1));

            System.out.print("Source Node: ");
            int source = sc.nextInt();

            System.out.print("Destination Node: ");
            int destination = sc.nextInt();

            System.out.print("Risk Weight: ");
            int weight = sc.nextInt();

            if (source < 0 || source >= vertices ||
                destination < 0 || destination >= vertices) {

                System.out.println("Invalid Node Number! Transaction Skipped.");
                continue;
            }

            edges.add(new Edge(source, destination, weight));
        }

        System.out.print("\nEnter Source Node for Analysis: ");
        int sourceNode = sc.nextInt();

        if (sourceNode < 0 || sourceNode >= vertices) {
            System.out.println("ERROR: Source Node must be between 0 and "
                    + (vertices - 1));
            return;
        }

        bellmanFord(vertices, sourceNode);

        sc.close();
    }
}
